    "executionRoleArn": "arn:aws:iam::601020071576:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "joke-api",
            "image": "601020071576.dkr.ecr.eu-west-1.amazonaws.com/joke-api:latest",
            "portMappings": [
                {
                    "containerPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "OPENAI_API_KEY",
                    "value": "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"
                },
                {
                    "name": "LANGCHAIN_TRACING_V2",
                    "value": "true"
                },
                {
                    "name": "LANGCHAIN_API_KEY",
                    "value": "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"
                },
                {
                    "name": "LANGCHAIN_PROJECT",
                    "value": "module5-joke-api"
